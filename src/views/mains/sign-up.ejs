<main>
  <h2>회원 가입</h2>
  <p>아래 양식을 작성해 주세요</p>
  <form action="sign-up" method="post">
    <label for="username">이메일: </label>
    <input type="email" name="username" id="username" placeholder="abc@abc.com" value="<%= locals.prev && prev.username %>" required>
    <label for="password">비밀번호: </label>
    <input type="password" name="password" id="password" required>
    <label for="password-confirm">비밀번호 확인: </label>
    <input type="password" name="password-confirm" id="password-confirm" required>
    <label for="last-name">성</label>
    <input type="text" name="last-name" id="last-name" value="<%= locals.prev && prev.lastName %>" required>
    <label for="first-name">이름</label>
    <input type="text" name="first-name" id="first-name" value="<%= locals.prev && prev.firstName %>" required>
    <button type="submit">회원가입</button>
  </form>
  <% if (locals.errors) { %>
  <%- include("../templae/error") %>
  <% } %>
</main>